{
    "include": ["src/**/*"],

    "compilerOptions": {
        "target": "es2015", 
        "declaration": true,
        "outDir": "./dist", 
        "rootDir": "./src",
        "module": "commonjs",
        "baseUrl": ".",
        "strict": true
    },

    "typedocOptions": {
        "entryPoints": ["src/index.ts"],
        "out": "docs",
        "excludeInternal": true,
        "excludePrivate": true,
        "intentionallyNotExported": [],
        "includeVersion": true,
        "readme": "none"
    }    
}